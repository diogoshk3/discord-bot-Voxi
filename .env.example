# Bot token (Discord Developer Portal -> Bot)
DISCORD_TOKEN=
# Application/Client ID (Discord Developer Portal -> General Information)
CLIENT_ID=
# Path to the Piper binary (e.g. C:\piper\piper.exe)
PIPER_PATH=piper
# Folder with Piper's .onnx models (e.g. C:\piper\models)
MODELS_DIR=./models
# Path to the SQLite database
DB_PATH=./tts.db
# Default voice (model name without extension)
DEFAULT_VOICE=en_US-amy-medium
# Default speed (1.0 = normal; higher values = slower in Piper)
DEFAULT_SPEED=1.0
# Maximum playback queue capacity
QUEUE_CAP=20
# Maximum number of characters per message
MAX_CHARS=300
# Per-user request limit per minute (leave room for normal conversation bursts)
RATE_PER_MIN=8
# TTS engine: 'piper' (default, local), 'neural' (official OpenAI API), or the legacy
# 'gtts'/'router' modes. The legacy modes call an unsupported Google Translate endpoint
# and are explicit operator opt-ins; do not use them for a service that requires a
# supported API contract. Invalid values fall back to Piper. Neural requires a key.
TTS_ENGINE=piper
# OpenAI API key — only needed when TTS_ENGINE=neural.
OPENAI_API_KEY=
# Minimum log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
# Bot presence/activity text (shown as "Listening to ...").
# Optional: if empty, uses the brand default "type it, hear it. • /setup".
# Setting it here overrides the default. Keep it short (Discord truncates long texts).
PRESENCE_TEXT=
# Port for the optional HTTP health endpoint (GET /health -> 200 {"status":"ok"}).
# Optional: if EMPTY/absent, NO server is started (default). Setting a
# port (e.g. 8080) enables a minimal server for uptime monitors (UptimeRobot).
# Exposes no sensitive data. See docs/GO-PUBLIC.md (24/7).
HEALTH_PORT=
# Sharding (opt-in, only for scaling near ~1000+ guilds). EMPTY/absent =>
# single-process (default — you don't need to touch this). 'auto' lets Discord
# choose the count; an integer >= 2 fixes the number of shards. Only takes effect
# with `npm run start:sharded`; normal `npm start` ignores this variable.
# NOTE: it is called BOT_SHARDS (not SHARDS) on purpose — SHARDS and SHARD_COUNT
# are reserved and read from the environment by the discord.js Client itself,
# which would break single-process `npm start`. Do not rename it to SHARDS.
BOT_SHARDS=
# top.gg webhook (opt-in, P11.5) — records the bot's top.gg votes.
# VOTE REWARD: each valid upvote grants the voter 12h of Vozen Plus perks
# (VOTE_REWARD_HOURS in src/vote.ts; consecutive votes stack the expiry).
# DEDICATED port for the webhook server (POST /webhook/topgg). EMPTY/absent =>
# NO server is started (default). Setting a port (e.g. 8081) enables it.
# It is a SEPARATE port from HEALTH_PORT on purpose (do not reuse the same one):
# don't mix a public uptime endpoint with an authenticated webhook endpoint.
TOPGG_WEBHOOK_PORT=
# Secret that top.gg sends in the Authorization header (set in the webhook
# panel on top.gg). RECOMMENDED to always set it: without it the webhook has NO
# authentication and anyone who finds the port can forge votes. If empty, the
# webhook by default does NOT start (SEC-01).
# Do not duplicate keys: dotenv uses the last value, so a later empty line silently
# replaces a valid secret. Startup validation warns about this condition.
TOPGG_WEBHOOK_SECRET=
# Footgun: start the top.gg webhook WITHOUT a secret (no authentication). Default off.
# Only set 'true' if you understand the risk (anyone who finds the port forges votes).
TOPGG_WEBHOOK_ALLOW_INSECURE=
# Wave 3 — top.gg API token to PUBLISH the server count (ranking/discovery).
# Different from the WEBHOOK_SECRET above: this is the API token (top.gg ->
# Edit -> Webhooks/API). EMPTY => auto-post does NOT start (opt-in). With a
# token, it publishes the server_count at startup and every 30 min.
TOPGG_TOKEN=
# Wave 3 — URL of a Discord webhook to SEND unexpected errors to (gateway/
# rejections/exceptions) for production monitoring. EMPTY => no sending (opt-in).
# Create it in: Channel settings -> Integrations -> Webhooks -> New webhook -> Copy URL.
# There is dedup (the same error does not spam the channel).
ERROR_WEBHOOK_URL=
# Per-segment multilingual synthesis. It is ON by default; set the exact value `false`
# to disable it globally. The current fixed-voice speech path may bypass segmentation.
MULTILINGUAL_SEGMENTS=
# Kokoro neural engine (OPT-IN, /voice set engine:Kokoro). AUTO-DETECTED from
# tools/kokoro-venv (install it with tools/setup-kokoro.ps1) — no env needed for a
# default install. Set KOKORO_CMD only to point at a custom sidecar command. Without
# the sidecar installed, choosing Kokoro transparently uses the configured default.
# Piper remains the safe default unless the operator explicitly selects another mode.
KOKORO_CMD=
# Languages Kokoro serves (locale prefixes, CSV). Anything else uses the default engine.
# Default = en,es,fr,hi,it,pt,ja (validated). Mandarin (zh) needs misaki[zh], excluded.
KOKORO_LANGS=

# Google HD engine (OPT-IN, Premium-only: /voice set engine:"Google HD"). Official
# Google Cloud Text-to-Speech, STANDARD voices. Without this key the `gcloud` path uses
# the configured default and makes no billable Google Cloud request.
# Cost: $4 per 1M chars, with a permanent 4M chars/month free tier. Create a Google
# Cloud project, enable the Text-to-Speech API, make an API key RESTRICTED to that API,
# and set a billing/quota alert. Keep this key ONLY here on the VPS (never in the repo).
GOOGLE_TTS_API_KEY=
# Cost safeguards (allowances). Tune without a redeploy. The bot counts chars ONLY on a
# real Google call (cache miss) and falls back to the configured default once spent. Worst
# case (pool spent, free tier gone): Plus $0.40 vs €1.99; 3-server pass $1.60 vs €3.99;
# 8-server pass $4.00 vs €7.99 — always profitable by construction.
# Per-request cap: longer text goes directly to the configured default.
GCLOUD_MAX_CHARS=500
# Personal Plus pool, per person per month (~2000 messages; max cost $0.40).
GCLOUD_PLUS_MONTHLY_CHARS=100000
# Pass pool per month, SHARED across the pass's servers (keyed by the pass owner). The
# tier is picked by seat count: 3-server pass -> PASS3, 8-server (or more) pass -> PASS8.
GCLOUD_PASS3_MONTHLY_CHARS=400000
GCLOUD_PASS8_MONTHLY_CHARS=1000000
# Global daily backstop (in-memory circuit-breaker against bugs/abuse). 0 = disabled.
GCLOUD_DAILY_CHAR_BUDGET=300000

# ─── Premium / pagamentos (Ko-fi) ────────────────────────────────────────────
# Todo o Premium é OPT-IN e INERTE sem estas vars — o bot corre exatamente como
# hoje até as definires. Fluxo: o cliente compra no Ko-fi, o webhook concede o
# premium à conta dele, e ele usa /premium activate no servidor (Premium) ou
# recebe o Plus direto.
#
# Página do Ko-fi mostrada no /premium info e no site. Mete a TUA página.
KOFI_URL=https://ko-fi.com/rexy00
# Webhook do Ko-fi: token de verificação (Ko-fi > Settings > API > Webhooks).
# VAZIO => o servidor de webhook NÃO arranca (vendas só via /vozengrant manual).
# Cuidado: não dupliques chaves neste ficheiro; o dotenv usa a ÚLTIMA — uma
# linha `KOFI_WEBHOOK_TOKEN=` vazia a seguir à boa desliga o webhook em silêncio.
KOFI_WEBHOOK_TOKEN=
# Porta local do endpoint do webhook (o teu host/reverse-proxy aponta o domínio
# para aqui, no caminho POST /). Default 3001.
KOFI_WEBHOOK_PORT=3001
# Itens da LOJA Ko-fi (ex.: passes ANUAIS) -> produto. Formato:
#   codigo:plano:dias[:licencas]   separados por virgulas
# O `codigo` e o direct_link_code do item (o que aparece no link ko-fi.com/s/<codigo>).
# PORQUE existe: um "Shop Order" do Ko-fi NAO traz o NOME do produto no webhook — so o
# codigo. As memberships (mensais) sao lidas pelo tier_name e nao precisam disto; os itens
# de loja precisam, senao a compra e ignorada em silencio.
# `plano` = plus | premium. `licencas` so conta no premium (default 3).
# VAZIO => sem produtos de loja (anual desligado). Entradas malformadas sao ignoradas.
# Exemplo:
#   KOFI_SHOP_MAP=a1b2c3:plus:365, d4e5f6:premium:365:3, g7h8i9:premium:365:8
KOFI_SHOP_MAP=
# Painel Premium do site: login com Discord e ver o estado da conta. Monta uma API de
# LEITURA (GET /api/me/premium) no MESMO servidor HTTP (mesma porta acima). OPT-IN:
# só arranca com PREMIUM_API_ENABLED=true. Precisa de HTTPS público (o mesmo
# reverse-proxy do webhook) e de o redirect URI do site estar registado na app do
# Discord (Developer Portal > OAuth2 > Redirects).
PREMIUM_API_ENABLED=false
# Origem do site permitida no CORS (só ela pode chamar a API do browser). Default = o
# domínio do site (vozen.org); muda se serves o site noutro domínio. Sem barra final.
PREMIUM_API_ORIGIN=https://vozen.org
# Comando OWNER-ONLY /vozengrant (conceder Premium/Plus à mão: recuperação de
# webhook, ofertas). É registado SÓ neste servidor de controlo (invisível ao
# público) e o handler valida o dono real (resolvido do Discord). VAZIO => o
# comando não é registado.
OWNER_GUILD_ID=
# Dono do bot (fallback explícito). Normalmente desnecessário — o dono é
# resolvido automaticamente via a application/Team no arranque.
OWNER_ID=

# Link de suporte/denúncia mostrado no /help (a Política de Desenvolvedor do
# Discord exige um canal de report). Default = servidor de suporte oficial.
SUPPORT_URL=

# Discord Premium Apps (monetização NATIVA do Discord, opcional — o Ko-fi
# funciona sem isto). Cria os SKUs no Developer Portal > Monetization e cola
# aqui os IDs; sem eles o sync de entitlements fica inerte ("só /redeem").
PREMIUM_GUILD_SKU_ID=
PREMIUM_USER_SKU_ID=

# Mostra o grupo de comandos /voice clone. VAZIO/0 = ESCONDIDO (default).
# O motor de clone (Chatterbox) precisa de GPU/RAM — nem carrega no VPS alojado
# (2 vCPU, 3.7 GB; ver docs/SPIKE-CLONE.md, pico 3.3 GB -> OOM). Só numa máquina
# capaz é que faz sentido: pôr CLONE_ENABLED=1 (variável REAL, não só no .env —
# o registo dos comandos corre antes do dotenv). Quem já gravou uma amostra
# apaga-a sempre por /privacy erase, mesmo com o grupo escondido.
CLONE_ENABLED=

# Comando do sidecar de clone de voz. VAZIO = auto-deteta tools/clone-venv
# (Scripts/python.exe no Windows OU bin/python no Linux). Só é preciso se o venv
# estiver noutro sítio. Ex.: /usr/bin/python3 /opt/clone/server.py
CLONE_CMD=

# Passphrase para CIFRAR as amostras de voz clonada (.wav) EM REPOUSO — dado
# biométrico (ToS §5(c) + RGPD). VAZIO = sem cifra (amostras em claro,
# retrocompatível). Usa uma passphrase forte e única; se a mudares, os .wav
# cifrados com a antiga deixam de decifrar (o clone cai na voz normal).
CLONE_KEY=

# ── Tuning avançado (defaults sensatos; só mexer com razão) ─────────────────
# Silêncio inicial antes da fala na leitura de canal (ms). Default 300.
MESSAGE_LEAD_MS=
# Parâmetros de síntese do Piper (naturalidade). Defaults calibrados por voz.
NOISE_SCALE=
NOISE_W=
SENTENCE_SILENCE=
# Legacy gTTS circuit breaker: consecutive-failure threshold and cooldown in ms.
# Defaults 3 / 60000.
GTTS_BREAKER_THRESHOLD=
GTTS_BREAKER_COOLDOWN_MS=
# Legacy gTTS chunks fetched concurrently (1 = serial). Default 3.
GTTS_CHUNK_CONCURRENCY=
# SECRET-04 (plano 032): força o PUT global de comandos mesmo sem mudanças (ignora o
# fingerprint em cache). Default OFF (só regista quando os comandos mudam).
FORCE_REGISTER=
# Modelo do Whisper para o /transcribe (STT). Default 'base' (calibrado para o VPS —
# ver docs/SPIKE-STT.md). Outros valores: tiny, small, medium... (mais lento/melhor).
WHISPER_MODEL=
# Pool de processos do Piper reutilizados entre sínteses (~4x mais rápido). Default ON
# (qualquer valor != '0'/'false'/'off' mantém ligado). Desliga com PIPER_PERSISTENT=0.
PIPER_PERSISTENT=
# Nº de vozes "quentes" mantidas no pool do Piper. Default 3.
PIPER_WARM_VOICES=
# Cap de processos do Piper a correr em simultâneo (anti-stampede de CPU/RAM). Default
# max(1, núcleos - 1).
PIPER_MAX_CONCURRENCY=
