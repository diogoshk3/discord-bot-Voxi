# Token do bot (Discord Developer Portal -> Bot)
DISCORD_TOKEN=
# Application/Client ID (Discord Developer Portal -> General Information)
CLIENT_ID=
# Caminho para o binario do Piper (ex.: C:\piper\piper.exe)
PIPER_PATH=piper
# Pasta com os modelos .onnx do Piper (ex.: C:\piper\models)
MODELS_DIR=./models
# Caminho para a base de dados SQLite
DB_PATH=./tts.db
# Voz por defeito (nome do modelo sem extensao)
DEFAULT_VOICE=en_US-amy-medium
# Velocidade por defeito (1.0 = normal; valores maiores = mais lento no Piper)
DEFAULT_SPEED=1.0
# Tempo de inatividade antes de sair do canal de voz (ms)
INACTIVITY_MS=300000
# Capacidade maxima da fila de reproducao
QUEUE_CAP=20
# Numero maximo de caracteres por mensagem
MAX_CHARS=300
# Limite de pedidos por utilizador por minuto
RATE_PER_MIN=5
# Motor TTS: 'piper' (default, self-host, gratis) ou 'neural' (OpenAI tts-1, premium).
# Valor invalido cai em 'piper' com aviso. 'neural' exige OPENAI_API_KEY (falha rapido se faltar).
TTS_ENGINE=piper
# Chave da API OpenAI — so necessaria quando TTS_ENGINE=neural.
OPENAI_API_KEY=
# Nivel minimo de log: debug | info | warn | error (default: info)
LOG_LEVEL=info
# Texto da presenca/atividade do bot (aparece como "Listening to ...").
# Opcional: se vazio, usa o default de marca "type it, hear it. • /setup".
# Definir aqui sobrepoe o default. Mantem curto (o Discord trunca textos longos).
PRESENCE_TEXT=
# Porta do health endpoint HTTP opcional (GET /health -> 200 {"status":"ok"}).
# Opcional: se VAZIO/ausente, NAO arranca servidor nenhum (default). Definir uma
# porta (ex.: 8080) ativa um servidor minimo para uptime monitors (UptimeRobot).
# Nao expoe dados sensiveis. Ver docs/GO-PUBLIC.md (24/7).
HEALTH_PORT=
# Sharding (opt-in, so para escalar perto dos ~1000+ guilds). VAZIO/ausente =>
# single-process (default — nao precisas de mexer aqui). 'auto' deixa o Discord
# escolher a contagem; um inteiro >= 2 fixa o numero de shards. So tem efeito com
# `npm run start:sharded`; o `npm start` normal ignora esta variavel.
# NOTA: chama-se BOT_SHARDS (nao SHARDS) de proposito — SHARDS e SHARD_COUNT sao
# reservadas e lidas pelo proprio Client do discord.js a partir do ambiente, o que
# partiria o `npm start` single-process. Nao renomear para SHARDS.
BOT_SHARDS=
# Webhook top.gg (opt-in, P11.5) — regista os votos do bot no top.gg.
# Porta DEDICADA do servidor de webhook (POST /webhook/topgg). VAZIO/ausente =>
# NAO arranca servidor nenhum (default). Definir uma porta (ex.: 8081) ativa-o.
# E uma porta SEPARADA do HEALTH_PORT de proposito (nao reutilizar a mesma): nao
# misturar um endpoint de uptime publico com um endpoint de webhook autenticado.
TOPGG_WEBHOOK_PORT=
# Secret que o top.gg envia no header Authorization (definido no painel do
# webhook em top.gg). RECOMENDADO definir sempre: sem ele o webhook fica SEM
# autenticacao e qualquer um que descubra a porta pode forjar votos. Se vazio, o
# servidor arranca na mesma mas avisa no log e aceita pedidos sem auth.
TOPGG_WEBHOOK_SECRET=
