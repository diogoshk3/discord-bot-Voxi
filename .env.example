# Token do bot (Discord Developer Portal -> Bot)
DISCORD_TOKEN=
# Application/Client ID (Discord Developer Portal -> General Information)
CLIENT_ID=
# Caminho para o binario do Piper (ex.: C:\piper\piper.exe)
PIPER_PATH=piper
# Pasta com os modelos .onnx do Piper (ex.: C:\piper\models)
MODELS_DIR=./models
# Caminho para a base de dados SQLite
DB_PATH=./tts.db
# Voz por defeito (nome do modelo sem extensao)
DEFAULT_VOICE=en_US-amy-medium
# Velocidade por defeito (1.0 = normal; valores maiores = mais lento no Piper)
DEFAULT_SPEED=1.0
# Tempo de inatividade antes de sair do canal de voz (ms)
INACTIVITY_MS=300000
# Capacidade maxima da fila de reproducao
QUEUE_CAP=20
# Numero maximo de caracteres por mensagem
MAX_CHARS=300
# Limite de pedidos por utilizador por minuto
RATE_PER_MIN=5
# Motor TTS: 'piper' (default, self-host, gratis) ou 'neural' (OpenAI tts-1, premium).
# Valor invalido cai em 'piper' com aviso. 'neural' exige OPENAI_API_KEY (falha rapido se faltar).
TTS_ENGINE=piper
# Chave da API OpenAI — so necessaria quando TTS_ENGINE=neural.
OPENAI_API_KEY=
# Nivel minimo de log: debug | info | warn | error (default: info)
LOG_LEVEL=info
# Texto da presenca/atividade do bot (aparece como "Listening to ...").
# Opcional: se vazio, usa o default de marca "type it, hear it. • /setup".
# Definir aqui sobrepoe o default. Mantem curto (o Discord trunca textos longos).
PRESENCE_TEXT=
# Porta do health endpoint HTTP opcional (GET /health -> 200 {"status":"ok"}).
# Opcional: se VAZIO/ausente, NAO arranca servidor nenhum (default). Definir uma
# porta (ex.: 8080) ativa um servidor minimo para uptime monitors (UptimeRobot).
# Nao expoe dados sensiveis. Ver docs/GO-PUBLIC.md (24/7).
HEALTH_PORT=
