{
  "name": "voxi",
  "version": "0.0.0",
  "private": true,
  "description": "Voxi — type it, hear it. Bot de TTS para Discord com voz neural gratis (Piper self-host) e fiabilidade.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:sharded": "node dist/shard.js",
    "test": "vitest run",
    "register": "tsx src/bot/registerCommands.ts"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.2",
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.2.0",
    "franc": "^5.0.0",
    "sodium-native": "^4.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.28.1": true,
    "@discordjs/opus@0.9.0": true,
    "ffmpeg-static@5.3.0": true
  }
}
